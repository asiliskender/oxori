{
  "name": "oxori",
  "version": "0.1.0",
  "description": "Agents read and write markdown knowledge bases — and find the right piece without scanning everything.",
  "type": "module",
  "bin": {
    "oxori": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "lint": "biome check src",
    "format": "biome format src --write",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
